# =============================================================================
# Digital Identity — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Supabase / PostgreSQL ---
# Found in: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# --- Supabase Storage (for ID photo uploads) ---
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # From: Settings → API → service_role
SUPABASE_STORAGE_BUCKET="identity-photos"            # Create this bucket in Supabase Storage

# --- JWT ---
JWT_SECRET="change-me-to-a-long-random-string-min-64-chars"
JWT_EXPIRES_IN="7d"

# --- Admin Bootstrap ---
# This key is required to hit POST /api/admin/create — keep it secret!
ADMIN_MASTER_SECRET="change-me-to-another-long-random-string"

# --- Email (Nodemailer) ---
# Example uses Gmail App Password — swap for SMTP of your choice
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Digital Identity <your-email@gmail.com>"
