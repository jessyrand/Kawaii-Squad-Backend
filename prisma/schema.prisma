// =============================================================================
// Digital Identity — Prisma Schema
// Database: PostgreSQL via Supabase
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")  // Required for Supabase connection pooling
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum IdentityStatus {
  PENDING
  CONFIRMED
  REJECTED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id           String         @id @default(cuid())
  fullName     String
  fatherName   String
  motherName   String
  dateOfBirth  DateTime
  placeOfBirth String
  email        String         @unique
  password     String         // bcrypt hash
  idPhotoUrl   String?        // Supabase Storage public URL
  role         Role           @default(USER)
  status       IdentityStatus @default(PENDING)
  rejectionReason String?     // Populated on REJECTED status

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status])
  @@index([email])
  @@map("users")
}
